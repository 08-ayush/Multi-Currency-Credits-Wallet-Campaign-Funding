# Server
NODE_ENV=development
PORT=4000

# Frontend origin for CORS
CLIENT_URL=http://localhost:5173

# Database (development)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=credits_wallet

# Database (test) - a separate database is used for the Jest suite
DB_NAME_TEST=credits_wallet_test

# JWT
JWT_SECRET=super-secret-change-me
JWT_EXPIRES_IN=7d

# Stripe (Test Mode)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=inr

# Success / cancel URLs used by Stripe Checkout
STRIPE_SUCCESS_URL=http://localhost:5173/wallet?payment=success
STRIPE_CANCEL_URL=http://localhost:5173/wallet?payment=cancel
